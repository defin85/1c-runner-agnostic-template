{
  "schemaVersion": 2,
  "profileName": "wsl",
  "projectName": "{{ project_name }}",
  "projectSlug": "{{ project_slug }}",
  "description": "Linux/WSL-first profile for direct platform execution with Xvfb GUI isolation and LD_PRELOAD linker compatibility contour",
  "notes": [
    "Этот preset показывает canonical standalone-server contour для ibcmd, но core capabilities по умолчанию остаются на designer.",
    "Если проекту нужен ibcmd на WSL/Linux, переключайте driver на нужной capability явно.",
    "Для Arch/WSL этот preset также показывает repo-owned LD_PRELOAD contour для локального запуска 1С через direct-platform."
  ],
  "runnerAdapter": "direct-platform",
  "platform": {
    "binaryPath": "/opt/1cv8/x86_64/8.3.27.1859/1cv8",
    "ibcmdPath": "/opt/1cv8/x86_64/8.3.27.1859/ibcmd",
    "ldPreload": {
      "enabled": true,
      "libraries": ["/usr/lib/libstdc++.so.6", "/usr/lib/libgcc_s.so.1"]
    },
    "xvfb": {
      "enabled": true,
      "serverArgs": ["-screen", "0", "1440x900x24", "-noreset"]
    }
  },
  "infobase": {
    "mode": "client-server",
    "server": "127.0.0.1:1541",
    "ref": "{{ project_slug|replace('-', '_') }}",
    "connectionStringOverride": null,
    "auth": {
      "mode": "os",
      "user": null,
      "passwordEnv": null
    }
  },
  "ibcmd": {
    "runtimeMode": "standalone-server",
    "serverAccess": {
      "mode": "data-dir",
      "dataDir": "/var/lib/onec/{{ project_slug }}-standalone"
    },
    "auth": {
      "user": "standalone-admin",
      "passwordEnv": "ONEC_IBCMD_PASSWORD"
    },
    "standalone": {
      "databasePath": "/var/lib/onec/{{ project_slug }}-standalone/db"
    }
  },
  "capabilities": {
    "createIb": {
      "driver": "designer"
    },
    "dumpSrc": {
      "driver": "designer",
      "outputDir": "./src/cf"
    },
    "loadSrc": {
      "driver": "designer",
      "sourceDir": "./src/cf"
    },
    "updateDb": {
      "driver": "designer"
    },
    "diffSrc": {
      "command": ["git", "diff", "--", "./src"]
    },
    "xunit": {
      "command": ["bash", "-lc", "echo TODO: direct platform xUnit contour"]
    },
    "bdd": {
      "command": ["bash", "-lc", "echo TODO: direct platform BDD contour"]
    },
    "smoke": {
      "command": ["bash", "-lc", "echo TODO: direct platform smoke contour"]
    },
    "publishHttp": {
      "command": ["bash", "-lc", "echo TODO: publish selected HTTP service"]
    }
  }
}
