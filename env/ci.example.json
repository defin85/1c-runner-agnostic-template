{
  "schemaVersion": 2,
  "profileName": "ci",
  "projectName": "{{ project_name }}",
  "projectSlug": "{{ project_slug }}",
  "description": "Example CI runtime profile for self-hosted 1C contour",
  "runnerAdapter": "direct-platform",
  "platform": {
    "binaryPath": "/opt/1cv8/x86_64/8.3.27.1859/1cv8",
    "ibcmdPath": "/opt/1cv8/x86_64/8.3.27.1859/ibcmd"
  },
  "infobase": {
    "mode": "client-server",
    "server": "127.0.0.1:1541",
    "ref": "{{ project_slug|replace('-', '_') }}_ci",
    "connectionStringOverride": null,
    "auth": {
      "mode": "user-password",
      "user": "ci-user",
      "passwordEnv": "ONEC_IB_PASSWORD"
    }
  },
  "ibcmd": {
    "connectionMode": "data-dir",
    "dataDir": "/var/lib/onec/{{ project_slug }}-standalone",
    "databasePath": "/var/lib/onec/{{ project_slug }}-standalone/db",
    "auth": {
      "user": "standalone-admin",
      "passwordEnv": "ONEC_IBCMD_PASSWORD"
    }
  },
  "capabilities": {
    "createIb": {
      "driver": "designer"
    },
    "dumpSrc": {
      "driver": "designer",
      "outputDir": "./src/cf"
    },
    "loadSrc": {
      "driver": "designer",
      "sourceDir": "./src/cf"
    },
    "updateDb": {
      "driver": "designer"
    },
    "diffSrc": {
      "command": ["git", "diff", "--", "./src"]
    },
    "xunit": {
      "command": ["bash", "-lc", "echo TODO: CI xUnit contour"]
    },
    "bdd": {
      "command": ["bash", "-lc", "echo TODO: CI BDD contour"]
    },
    "smoke": {
      "command": ["bash", "-lc", "echo TODO: CI smoke contour"]
    },
    "publishHttp": {
      "command": ["bash", "-lc", "echo TODO: CI publish HTTP service"]
    }
  }
}
