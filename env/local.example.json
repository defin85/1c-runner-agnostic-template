{
  "schemaVersion": 2,
  "profileName": "local",
  "projectName": "{{ project_name }}",
  "projectSlug": "{{ project_slug }}",
  "description": "Minimal direct-platform runtime profile example",
  "runnerAdapter": "direct-platform",
  "notes": [
    "Этот файл является примером structured runtime profile.",
    "Реальные секреты не храните в JSON; используйте passwordEnv и внешние env vars."
  ],
  "platform": {
    "binaryPath": "/opt/1cv8/x86_64/8.3.27.1859/1cv8"
  },
  "infobase": {
    "mode": "file",
    "filePath": "/var/tmp/{{ project_slug }}",
    "connectionStringOverride": null,
    "auth": {
      "mode": "os",
      "user": null,
      "passwordEnv": null
    }
  },
  "capabilities": {
    "dumpSrc": {
      "outputDir": "./src/cf"
    },
    "loadSrc": {
      "sourceDir": "./src/cf"
    },
    "diffSrc": {
      "command": ["git", "diff", "--", "./src"]
    },
    "xunit": {
      "command": ["bash", "-lc", "echo TODO: run xUnit checks"]
    },
    "bdd": {
      "command": ["bash", "-lc", "echo TODO: run BDD checks"]
    },
    "smoke": {
      "command": ["bash", "-lc", "echo TODO: run smoke checks"]
    },
    "publishHttp": {
      "command": ["bash", "-lc", "echo TODO: publish HTTP service"]
    }
  }
}
