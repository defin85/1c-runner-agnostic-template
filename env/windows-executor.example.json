{
  "schemaVersion": 2,
  "profileName": "windows-executor",
  "projectName": "[[[ project_name ]]]",
  "projectSlug": "[[[ project_slug ]]]",
  "description": "Remote Windows execution profile for UI-heavy or TestClient flows",
  "runnerAdapter": "remote-windows",
  "notes": [
    "Используйте этот профиль, если UI/TestClient лучше работают на Windows-хосте или в Windows VM.",
    "Стандартные операции create/load/dump/update будут собирать argv из structured profile и передавать их в scripts/adapters/remote-windows.sh.",
    "Ibcmd driver не поддерживается с runnerAdapter=remote-windows в текущем release; для core capabilities оставляйте driver=designer."
  ],
  "platform": {
    "binaryPath": "C:/Program Files/1cv8/8.3.27.1859/bin/1cv8.exe"
  },
  "infobase": {
    "mode": "client-server",
    "server": "win-1c:1541",
    "ref": "[[[ project_slug|replace('-', '_') ]]]",
    "connectionStringOverride": null,
    "auth": {
      "mode": "user-password",
      "user": "Administrator",
      "passwordEnv": "ONEC_IB_PASSWORD"
    }
  },
  "capabilities": {
    "createIb": {
      "driver": "designer"
    },
    "dumpSrc": {
      "driver": "designer",
      "outputDir": "./src/cf"
    },
    "loadSrc": {
      "driver": "designer",
      "sourceDir": "./src/cf"
    },
    "updateDb": {
      "driver": "designer"
    },
    "diffSrc": {
      "command": ["git", "diff", "--", "./src"]
    },
    "xunit": {
      "command": ["powershell", "-File", "C:/1c/run-xunit.ps1"]
    },
    "bdd": {
      "command": ["powershell", "-File", "C:/1c/run-bdd.ps1"]
    },
    "smoke": {
      "command": ["powershell", "-File", "C:/1c/run-smoke.ps1"]
    },
    "publishHttp": {
      "command": ["powershell", "-File", "C:/1c/publish-http.ps1"]
    }
  }
}
