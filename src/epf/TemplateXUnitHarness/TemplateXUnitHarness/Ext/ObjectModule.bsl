Перем КонтекстЯдра;
Перем Утверждения;

Процедура Инициализация(КонтекстЯдраПараметр) Экспорт

	КонтекстЯдра = КонтекстЯдраПараметр;
	Утверждения = КонтекстЯдра.Плагин("БазовыеУтверждения");

КонецПроцедуры

Процедура ЗаполнитьНаборТестов(НаборТестов, КонтекстЯдраПараметр) Экспорт

	Инициализация(КонтекстЯдраПараметр);

	НаборТестов.НачатьГруппу("Template xUnit harness", Ложь);

	ТестовыеПараметры = НаборТестов.ПараметрыТеста(Ложь);
	НаборТестов.Добавить(
		"Fact_НормализацияУдаляетПустыеИПробельныеЗначения",
		ТестовыеПараметры,
		"Template harness: blank values are removed");

	ТестовыеПараметры = НаборТестов.ПараметрыТеста(Ложь);
	НаборТестов.Добавить(
		"Fact_НормализацияСохраняетПорядокНепустыхЗначений",
		ТестовыеПараметры,
		"Template harness: order of non-empty values stays stable");

	ТестовыеПараметры = НаборТестов.ПараметрыТеста(Ложь);
	НаборТестов.Добавить(
		"Fact_НормализацияПреобразуетНеСтроковыеЗначения",
		ТестовыеПараметры,
		"Template harness: non-string values are normalized via string conversion");

КонецПроцедуры

Процедура Fact_НормализацияУдаляетПустыеИПробельныеЗначения(Транзакция = Ложь) Экспорт

	ИсходныеЗначения = Новый Массив;
	ИсходныеЗначения.Добавить("");
	ИсходныеЗначения.Добавить("  ");
	ИсходныеЗначения.Добавить(Символы.ПС);
	ИсходныеЗначения.Добавить("alpha");
	Результат = НормализоватьНепустыеСтроки(ИсходныеЗначения);

	Утверждения.ПроверитьИстину(
		Результат.Количество() = 1,
		"Ожидалась только одна непустая строка после нормализации");
	Утверждения.ПроверитьИстину(
		Результат[0] = "alpha",
		"Непустое значение должно сохраняться после удаления пустых и пробельных строк");

КонецПроцедуры

Процедура Fact_НормализацияСохраняетПорядокНепустыхЗначений(Транзакция = Ложь) Экспорт

	ИсходныеЗначения = Новый Массив;
	ИсходныеЗначения.Добавить(" beta ");
	ИсходныеЗначения.Добавить("");
	ИсходныеЗначения.Добавить("gamma");
	ИсходныеЗначения.Добавить(" delta ");
	Результат = НормализоватьНепустыеСтроки(ИсходныеЗначения);

	Утверждения.ПроверитьИстину(
		Результат.Количество() = 3,
		"Ожидалось три непустых элемента после нормализации");
	Утверждения.ПроверитьИстину(
		Результат[0] = "beta",
		"Первый непустой элемент должен сохранить исходный порядок");
	Утверждения.ПроверитьИстину(
		Результат[1] = "gamma",
		"Второй непустой элемент должен сохранить исходный порядок");
	Утверждения.ПроверитьИстину(
		Результат[2] = "delta",
		"Третий непустой элемент должен сохранить исходный порядок");

КонецПроцедуры

Процедура Fact_НормализацияПреобразуетНеСтроковыеЗначения(Транзакция = Ложь) Экспорт

	ИсходныеЗначения = Новый Массив;
	ИсходныеЗначения.Добавить(1);
	ИсходныеЗначения.Добавить(2);
	ИсходныеЗначения.Добавить(" 3 ");
	Результат = НормализоватьНепустыеСтроки(ИсходныеЗначения);

	Утверждения.ПроверитьИстину(
		Результат.Количество() = 3,
		"Ожидалось, что числовые и строковые значения будут представлены строками");
	Утверждения.ПроверитьИстину(
		Результат[0] = "1",
		"Число должно приводиться к строке");
	Утверждения.ПроверитьИстину(
		Результат[1] = "2",
		"Числовое значение должно приводиться к строковому представлению");
	Утверждения.ПроверитьИстину(
		Результат[2] = "3",
		"Пробельная строка должна быть нормализована и сохранить порядок");

КонецПроцедуры

Функция НормализоватьНепустыеСтроки(Значения) Экспорт

	Результат = Новый Массив;

	Для Каждого Значение Из Значения Цикл
		ТекущееЗначение = СокрЛП(Строка(Значение));
		Если ТекущееЗначение = "" Тогда
			Продолжить;
		КонецЕсли;

		Результат.Добавить(ТекущееЗначение);
	КонецЦикла;

	Возврат Результат;

КонецФункции
