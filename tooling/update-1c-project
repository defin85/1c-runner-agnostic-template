#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  update-1c-project [destination] [options]

Options:
  -h, --help                 Show this help
  -r, --vcs-ref REF          Update to a specific template git ref/tag/commit
      --pretend              Run overlay apply in dry-run mode

Examples:
  update-1c-project
  update-1c-project ~/code/my-project
  update-1c-project ~/code/my-project --vcs-ref v0.1.1
  update-1c-project . --pretend --vcs-ref HEAD

Notes:
  - If destination is omitted, current directory is used.
  - The destination must be a generated project that ships scripts/template/update-template.sh.
EOF
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "command not found: $1"
}

destination="."
destination_set=0
vcs_ref=""
pretend=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -r|--vcs-ref)
      [ "$#" -ge 2 ] || die "--vcs-ref requires a value"
      vcs_ref="$2"
      shift 2
      ;;
    --vcs-ref=*)
      vcs_ref="${1#*=}"
      shift
      ;;
    --pretend)
      pretend=1
      shift
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      if [ "$destination_set" -eq 0 ]; then
        destination="$1"
        destination_set=1
        shift
      else
        die "unexpected positional argument: $1"
      fi
      ;;
  esac
done

if [ ! -d "$destination" ]; then
  die "destination is not a directory: $destination"
fi

update_script="$destination/scripts/template/update-template.sh"
[ -x "$update_script" ] || die "generated project does not provide $update_script"

cmd=(./scripts/template/update-template.sh)

if [ -n "$vcs_ref" ]; then
  cmd+=(--vcs-ref "$vcs_ref")
fi

if [ "$pretend" -eq 1 ]; then
  cmd+=(--pretend)
fi

printf 'Running: '
printf '%q ' "${cmd[@]}"
printf '\n'

(cd "$destination" && "${cmd[@]}")
